@import "tailwindcss";

/* TopGame Thailand Brand Colors & Fonts */
@theme {
  --color-tg-red: #FF1A1A;
  --color-tg-dark-red: #B30000;
  --color-tg-black: #000000;
  --color-tg-surface: #0A0A0A;
  --color-tg-surface-md: #1F1F1F;
  --color-tg-surface-lg: #2A2A2A;
  --color-tg-silver: #E8E8E8;
  --color-tg-muted: #CFCFCF;
  --color-tg-dim: #888888;
  --color-tg-live: #FF6B35;
  --color-tg-news: #4A90D9;
  --color-tg-review: #4DCC8A;
  --color-tg-tech: #A855F7;
  --color-tg-tournament: #FFD700;

  --font-bebas: 'Bebas Neue', 'Anton', 'Oswald', sans-serif;
  --font-kanit: 'Kanit', 'Prompt', sans-serif;
  --font-prompt: 'Prompt', 'Kanit', sans-serif;
  --font-inter: 'Inter', 'Segoe UI', system-ui, sans-serif;
}

/* Custom Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #0A0A0A; }
::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #FF1A1A; }

/* Nav blur on scroll */
.nav-blur {
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* Line Clamp */
.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Card Hover */
.card-hover {
  transition: all 0.3s ease;
}
.card-hover:hover .card-img {
  transform: scale(1.05);
}
.card-img {
  transition: transform 0.5s ease;
}

/* Hero Gradient */
.hero-overlay {
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100%);
}

/* Glow Bar */
.glow-bar {
  height: 3px;
  background: linear-gradient(90deg, transparent, #FF1A1A, transparent);
  box-shadow: 0 0 20px rgba(255,26,26,0.5);
}

/* Category Tabs */
.cat-tab {
  padding: 8px 16px;
  color: #888;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}
.cat-tab:hover { color: #fff; }
.cat-tab.active {
  color: #FF1A1A;
  border-bottom-color: #FF1A1A;
}

/* Latest News Item */
.latest-item {
  padding: 12px 0;
  border-bottom: 1px solid #2A2A2A;
}
.latest-item:last-child { border-bottom: none; }
.latest-item:hover .latest-title { color: #FF1A1A; }
.latest-title { transition: color 0.2s ease; }

/* Minimal card */
.minimal-card {
  border-radius: 8px;
  overflow: hidden;
}

/* Section Title */
.section-title {
  font-family: 'Kanit', sans-serif;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 1.5rem;
  line-height: 1.1;
  color: #fff;
}

/* Overline label */
.overline-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}